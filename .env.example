# EmailJS Environment Variables
#
# Copy this file to .env and fill in your actual values.
# Never commit your real .env file to version control.
# The PUBLIC KEY is already embedded in emailService.js (it is safe to expose).
# Do NOT add your EmailJS private/secret key here.

# ── EmailJS ────────────────────────────────────────────────────────────────────

# Your EmailJS Service ID (found in EmailJS dashboard → Email Services)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx

# Template ID for the "Book a Session" form
# (EmailJS dashboard → Email Templates → your booking template)
VITE_EMAILJS_BOOKING_TEMPLATE=template_xxxxxxx

# Template ID for the "Contact" form
# (EmailJS dashboard → Email Templates → your contact template)
VITE_EMAILJS_CONTACT_TEMPLATE=template_xxxxxxx

# ── Existing Variables (keep as-is) ───────────────────────────────────────────
VITE_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_PUBLIC_SUPABASE_URL=https://your-project.helloreaddy.com/
